{
  "name": "@kubernetes-models/seldon-core-operator",
  "version": "1.0.1",
  "type": "module",
  "description": "seldon core operator",
  "repository": {
    "type": "git",
    "url": "https://github.com/tommy351/kubernetes-models-ts.git"
  },
  "homepage": "https://github.com/tommy351/kubernetes-models-ts/tree/master/third-party/seldon-core-operator",
  "author": "chris Hsieh <chris@dcard.cc>",
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "go-generate && publish-scripts build",
    "prepack": "publish-scripts prepack"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": true
  },
  "keywords": [
    "kubernetes",
    "kubernetes-models",
    "seldon-core-operator"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@kubernetes-models/apimachinery": "workspace:^",
    "@kubernetes-models/base": "workspace:^",
    "@kubernetes-models/validate": "workspace:^",
    "kubernetes-models": "workspace:^"
  },
  "devDependencies": {
    "@kubernetes-models/go-generate": "workspace:^",
    "@kubernetes-models/publish-scripts": "workspace:^",
    "vitest": "^4.1.5"
  },
  "go-generate": {
    "input": [
      "github.com/seldonio/seldon-core/operator/apis/machinelearning.seldon.io/v1"
    ],
    "output": "./gen"
  }
}

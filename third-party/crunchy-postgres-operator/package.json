{
  "name": "@kubernetes-models/crunchy-postgres-operator",
  "version": "0.0.0",
  "type": "module",
  "description": "Crunchy Data Postgres Operator (PGO) models",
  "repository": {
    "type": "git",
    "url": "https://github.com/tommy351/kubernetes-models-ts.git"
  },
  "homepage": "https://github.com/tommy351/kubernetes-models-ts/tree/master/third-party/crunchy-postgres-operator",
  "author": "Tommy Chen <tommy@dcard.cc>",
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "crd-generate && publish-scripts build",
    "prepack": "publish-scripts prepack"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": true
  },
  "keywords": [
    "kubernetes",
    "kubernetes-models",
    "crunchy-data",
    "postgres-operator",
    "pgo",
    "postgres"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@kubernetes-models/apimachinery": "workspace:^",
    "@kubernetes-models/base": "workspace:^",
    "@kubernetes-models/validate": "workspace:^"
  },
  "devDependencies": {
    "@kubernetes-models/crd-generate": "workspace:^",
    "@kubernetes-models/publish-scripts": "workspace:^",
    "vitest": "^4.1.5"
  },
  "crd-generate": {
    "input": [
      "https://raw.githubusercontent.com/CrunchyData/postgres-operator/v6.0.1/config/crd/bases/postgres-operator.crunchydata.com_pgadmins.yaml",
      "https://raw.githubusercontent.com/CrunchyData/postgres-operator/v6.0.1/config/crd/bases/postgres-operator.crunchydata.com_pgupgrades.yaml",
      "https://raw.githubusercontent.com/CrunchyData/postgres-operator/v6.0.1/config/crd/bases/postgres-operator.crunchydata.com_postgresclusters.yaml"
    ],
    "output": "./gen"
  }
}

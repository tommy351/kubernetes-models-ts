{
  "name": "@kubernetes-models/trivy-operator",
  "version": "0.0.0",
  "type": "module",
  "description": "Trivy Operator models",
  "repository": {
    "type": "git",
    "url": "https://github.com/tommy351/kubernetes-models-ts.git"
  },
  "homepage": "https://github.com/tommy351/kubernetes-models-ts/tree/master/third-party/trivy-operator",
  "author": "Tommy Chen <tommy@dcard.cc>",
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "crd-generate && publish-scripts build",
    "prepack": "publish-scripts prepack"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": true
  },
  "keywords": [
    "kubernetes",
    "kubernetes-models",
    "trivy",
    "trivy-operator",
    "aqua-security"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@kubernetes-models/apimachinery": "workspace:^",
    "@kubernetes-models/base": "workspace:^",
    "@kubernetes-models/validate": "workspace:^"
  },
  "devDependencies": {
    "@kubernetes-models/crd-generate": "workspace:^",
    "@kubernetes-models/publish-scripts": "workspace:^",
    "vitest": "^4.1.5"
  },
  "crd-generate": {
    "input": [
      "https://raw.githubusercontent.com/aquasecurity/trivy-operator/v0.30.1/deploy/helm/crds/aquasecurity.github.io_clustercompliancereports.yaml",
      "https://raw.githubusercontent.com/aquasecurity/trivy-operator/v0.30.1/deploy/helm/crds/aquasecurity.github.io_clusterconfigauditreports.yaml",
      "https://raw.githubusercontent.com/aquasecurity/trivy-operator/v0.30.1/deploy/helm/crds/aquasecurity.github.io_clusterinfraassessmentreports.yaml",
      "https://raw.githubusercontent.com/aquasecurity/trivy-operator/v0.30.1/deploy/helm/crds/aquasecurity.github.io_clusterrbacassessmentreports.yaml",
      "https://raw.githubusercontent.com/aquasecurity/trivy-operator/v0.30.1/deploy/helm/crds/aquasecurity.github.io_clustersbomreports.yaml",
      "https://raw.githubusercontent.com/aquasecurity/trivy-operator/v0.30.1/deploy/helm/crds/aquasecurity.github.io_clustervulnerabilityreports.yaml",
      "https://raw.githubusercontent.com/aquasecurity/trivy-operator/v0.30.1/deploy/helm/crds/aquasecurity.github.io_configauditreports.yaml",
      "https://raw.githubusercontent.com/aquasecurity/trivy-operator/v0.30.1/deploy/helm/crds/aquasecurity.github.io_exposedsecretreports.yaml",
      "https://raw.githubusercontent.com/aquasecurity/trivy-operator/v0.30.1/deploy/helm/crds/aquasecurity.github.io_infraassessmentreports.yaml",
      "https://raw.githubusercontent.com/aquasecurity/trivy-operator/v0.30.1/deploy/helm/crds/aquasecurity.github.io_rbacassessmentreports.yaml",
      "https://raw.githubusercontent.com/aquasecurity/trivy-operator/v0.30.1/deploy/helm/crds/aquasecurity.github.io_sbomreports.yaml",
      "https://raw.githubusercontent.com/aquasecurity/trivy-operator/v0.30.1/deploy/helm/crds/aquasecurity.github.io_vulnerabilityreports.yaml"
    ],
    "output": "./gen"
  }
}

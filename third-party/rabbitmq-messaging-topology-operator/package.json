{
  "name": "@kubernetes-models/rabbitmq-messaging-topology-operator",
  "version": "2.0.0",
  "type": "module",
  "description": "The operator allow developers to create and manage RabbitMQ messaging topologies within a RabbitMQ cluster using a declarative Kubernetes API",
  "repository": {
    "type": "git",
    "url": "https://github.com/tommy351/kubernetes-models-ts.git"
  },
  "homepage": "https://github.com/tommy351/kubernetes-models-ts/tree/master/third-party/rabbitmq-messaging-topology-operator",
  "author": "Justin Chen <mail@justin0u0.com>",
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "go-generate && publish-scripts build",
    "prepack": "publish-scripts prepack"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": true
  },
  "keywords": [
    "kubernetes",
    "kubernetes-models",
    "rabbitmq-messaging-topology-operator"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@kubernetes-models/apimachinery": "workspace:^",
    "@kubernetes-models/base": "workspace:^",
    "@kubernetes-models/validate": "workspace:^",
    "kubernetes-models": "workspace:^"
  },
  "devDependencies": {
    "@kubernetes-models/go-generate": "workspace:^",
    "@kubernetes-models/publish-scripts": "workspace:^",
    "vitest": "^4.1.5"
  },
  "go-generate": {
    "input": [
      "github.com/rabbitmq/messaging-topology-operator/api/v1alpha1",
      "github.com/rabbitmq/messaging-topology-operator/api/v1beta1"
    ],
    "output": "./gen"
  }
}

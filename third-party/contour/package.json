{
  "name": "@kubernetes-models/contour",
  "version": "5.0.1",
  "type": "module",
  "description": "Contour models",
  "repository": {
    "type": "git",
    "url": "https://github.com/tommy351/kubernetes-models-ts.git"
  },
  "homepage": "https://github.com/tommy351/kubernetes-models-ts/tree/master/third-party/contour",
  "author": "Tommy Chen <tommy351@gmail.com>",
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "go-generate && publish-scripts build",
    "prepack": "publish-scripts prepack"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": true
  },
  "keywords": [
    "kubernetes",
    "kubernetes-models",
    "contour"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@kubernetes-models/apimachinery": "workspace:^",
    "@kubernetes-models/base": "workspace:^",
    "@kubernetes-models/validate": "workspace:^",
    "kubernetes-models": "workspace:^"
  },
  "devDependencies": {
    "@kubernetes-models/go-generate": "workspace:^",
    "@kubernetes-models/publish-scripts": "workspace:^",
    "vitest": "^4.1.5"
  },
  "go-generate": {
    "input": [
      "github.com/projectcontour/contour/apis/projectcontour/v1",
      "github.com/projectcontour/contour/apis/projectcontour/v1alpha1"
    ],
    "output": "./gen"
  }
}

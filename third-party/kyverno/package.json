{
  "name": "@kubernetes-models/kyverno",
  "version": "2.0.0",
  "type": "module",
  "description": "Kyverno models",
  "repository": {
    "type": "git",
    "url": "https://github.com/tommy351/kubernetes-models-ts.git"
  },
  "homepage": "https://github.com/tommy351/kubernetes-models-ts/tree/master/third-party/kyverno",
  "author": "benjamin99 <cknomber1@gmail.com>",
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "go-generate && publish-scripts build",
    "prepack": "publish-scripts prepack"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": true
  },
  "keywords": [
    "kubernetes",
    "kubernetes-models",
    "kyverno"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@kubernetes-models/apimachinery": "workspace:^",
    "@kubernetes-models/base": "workspace:^",
    "@kubernetes-models/validate": "workspace:^",
    "kubernetes-models": "workspace:^"
  },
  "devDependencies": {
    "@kubernetes-models/go-generate": "workspace:^",
    "@kubernetes-models/publish-scripts": "workspace:^",
    "vitest": "^4.1.5"
  },
  "go-generate": {
    "input": [
      "github.com/kyverno/api/api/policies.kyverno.io/v1",
      "github.com/kyverno/api/api/policies.kyverno.io/v1alpha1",
      "github.com/kyverno/api/api/policies.kyverno.io/v1beta1",
      "github.com/kyverno/kyverno/api/kyverno/v1",
      "github.com/kyverno/kyverno/api/kyverno/v1beta1",
      "github.com/kyverno/kyverno/api/kyverno/v2",
      "github.com/kyverno/kyverno/api/kyverno/v2alpha1",
      "github.com/kyverno/kyverno/api/kyverno/v2beta1",
      "github.com/kyverno/kyverno/api/policyreport/v1alpha2",
      "github.com/kyverno/kyverno/api/reports/v1"
    ],
    "output": "./gen"
  }
}
